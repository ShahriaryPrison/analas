// prisma/schema.prisma
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  // Notice: The 'url' line is GONE. This is intentional in v7.
}

enum Plan {
  FREE
  PRO
  BUSINESS
  ENTERPRISE
}

model User {
  id                    String    @id @default(cuid())
  email                 String    @unique
  phone                 String?   @unique
  passwordHash          String
  name                  String?
  emailVerified         DateTime?
  phoneVerified         DateTime?
  emailVerificationToken String?   @unique
  verificationOtp       String?
  otpExpiresAt          DateTime?
  workspaces            WorkspaceMember[] 
}

model Workspace {
  id                String            @id @default(cuid())
  name              String
  tenantId          String            @unique
  plan              Plan              @default(FREE)
  internalBillingCustomerId  String?   @unique
  internalSubscriptionId     String?   @unique
  billingCycleStart          DateTime?
  currentMonthEvents         Int       @default(0)
  members           WorkspaceMember[]
  apiKeys           ApiKey[]
  dashboards        Dashboard[]
  invites           WorkspaceInvite[]
  inviteLinkEnabled Boolean           @default(false)
  eventSettings     EventSetting[]
}

model WorkspaceMember {
  id          String    @id @default(cuid())
  role        String    
  userId      String
  workspaceId String
  user        User      @relation(fields: [userId], references: [id])
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  @@unique([userId, workspaceId]) 
}

model ApiKey {
  id          String   @id @default(cuid())
  keyHash     String   @unique
  name        String
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  createdAt   DateTime @default(now())
}

model Dashboard {
  id          String   @id @default(cuid())
  name        String
  isPublic    Boolean  @default(false)
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  insights    Insight[]
}

model Insight {
  id          String   @id @default(cuid())
  name        String
  type        String
  queryConfig Json
  position    Int      @default(0)
  dashboardId String
  dashboard   Dashboard @relation(fields: [dashboardId], references: [id])
}

model WorkspaceInvite {
  id          String    @id @default(cuid())
  token       String    @unique
  email       String?                   // null = public link (anyone with the token)
  role        String    @default("MEMBER")
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  createdAt   DateTime  @default(now())
  expiresAt   DateTime?                 // optional expiry for public links
  usedAt      DateTime?                 // stamped when invite is accepted
}

model StriteSession {
  token       String   @id
  workspaceId String
  createdAt   DateTime @default(now())
}

model EventSetting {
  id          String    @id @default(cuid())
  workspaceId String
  eventName   String
  isArchived  Boolean   @default(false)
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  createdAt   DateTime  @default(now())

  @@unique([workspaceId, eventName])
}