// prisma/schema.prisma
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  // Notice: The 'url' line is GONE. This is intentional in v7.
}

enum Plan {
  FREE
  PRO
  BUSINESS
  ENTERPRISE
}

model User {
  id                    String    @id @default(cuid())
  email                 String    @unique
  phone                 String?   @unique
  passwordHash          String
  name                  String?
  emailVerified         DateTime?
  phoneVerified         DateTime?
  emailVerificationToken String?   @unique
  verificationOtp       String?
  otpExpiresAt          DateTime?
  workspaces            WorkspaceMember[] 
}

model Workspace {
  id                String            @id @default(cuid())
  name              String
  tenantId          String            @unique
  plan              Plan              @default(FREE)
  internalBillingCustomerId  String?   @unique
  internalSubscriptionId     String?   @unique
  billingCycleStart          DateTime?
  currentMonthEvents         Int       @default(0)
  members           WorkspaceMember[]
  apiKeys           ApiKey[]
  dashboards        Dashboard[]
  invites           WorkspaceInvite[]
  inviteLinkEnabled Boolean           @default(false)
  eventSettings     EventSetting[]
  sessionRecordings SessionRecording[]
  publicToken       String?           @unique
  allowedDomains    String[]          @default([])
}


model WorkspaceMember {
  id          String    @id @default(cuid())
  role        String    
  userId      String
  workspaceId String
  user        User      @relation(fields: [userId], references: [id])
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  @@unique([userId, workspaceId]) 
}

model ApiKey {
  id          String   @id @default(cuid())
  keyHash     String   @unique
  name        String
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  createdAt   DateTime @default(now())
}

model Dashboard {
  id          String   @id @default(cuid())
  name        String
  isPublic    Boolean  @default(false)
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  insights    Insight[]
}

model Insight {
  id          String   @id @default(cuid())
  name        String
  type        String
  queryConfig Json
  position    Int      @default(0)
  dashboardId String
  dashboard   Dashboard @relation(fields: [dashboardId], references: [id])
}

model WorkspaceInvite {
  id          String    @id @default(cuid())
  token       String    @unique
  email       String?                   // null = public link (anyone with the token)
  role        String    @default("MEMBER")
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  createdAt   DateTime  @default(now())
  expiresAt   DateTime?                 // optional expiry for public links
  usedAt      DateTime?                 // stamped when invite is accepted
}

model StriteSession {
  token       String   @id
  workspaceId String
  createdAt   DateTime @default(now())
}

model EventSetting {
  id          String    @id @default(cuid())
  workspaceId String
  eventName   String
  isArchived  Boolean   @default(false)
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  createdAt   DateTime  @default(now())

  @@unique([workspaceId, eventName])
}

// Session Recording — metadata in Postgres, event chunks as gzipped NDJSON via RecordingStore.
model SessionRecording {
  id          String    @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  distinctId  String    @default("")
  duration    Int       @default(0)  // seconds, updated with each chunk
  browser     String?
  os          String?
  pagePath    String?                // first path of the session
  storageKey  String                 // relative session key "<workspaceId>/<sessionId>"
  chunkCount  Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([workspaceId])
  @@index([distinctId])
  @@index([createdAt])
  @@index([workspaceId, createdAt])
}
