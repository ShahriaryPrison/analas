# ==========================================
# Database Configuration
# ==========================================
# If running via Docker Compose, use 'postgres' as the host. If running locally, use 'localhost'.
DATABASE_URL="postgresql://admin:postgres_pass@postgres:5432/saas_users"

# Clickhouse connection
CLICKHOUSE_URL="http://clickhouse:8123"
CLICKHOUSE_USER="admin"
CLICKHOUSE_PASSWORD="analytics_pass"

# ==========================================
# NextAuth / Authentication
# ==========================================
# The public URL of your application. MUST match your domain in production.
# Example: https://analas.app or http://123.45.67.89
NEXTAUTH_URL="http://localhost:3000"

# Secret used to encrypt session cookies. MUST be set in production!
# Generate one using: openssl rand -base64 32
NEXTAUTH_SECRET="generate-a-secure-random-string-here"

# ==========================================
# Billing Configuration (Strite)
# ==========================================
# True to enable limit enforcement in cloud-hosted mode, False for self-hosted unlimited mode.
NEXT_PUBLIC_IS_CLOUD_HOSTED="true"

# Strite API Details
STRITE_API_URL="https://your-strite-domain.com"
STRITE_API_KEY="strite_live_xxxxxxxxxxxxxxxxxxxxxxxx"

# Webhook verification secret (obtained from Strite Developer Portal)
STRITE_WEBHOOK_SECRET="strite_webhook_secret_here"

# ==========================================
# SMS Provider Configuration
# ==========================================
# Supported values: "console" (logs OTP code to stdout), "kavenegar"
SMS_PROVIDER="console"

# Kavenegar Credentials (only needed if SMS_PROVIDER="kavenegar")
KAVENEGAR_API_KEY="kavenegar_api_key_here"
KAVENEGAR_OTP_TEMPLATE="verify"

# ==========================================
# Session Recordings & S3 Storage
# ==========================================
# Choose storage driver: "disk" (local folder) or "s3" (MinIO, AWS S3, Arvan Cloud, etc.)
RECORDINGS_STORAGE="disk"
RECORDINGS_DIR="/recordings"

# S3 Configuration (only used if RECORDINGS_STORAGE="s3")
S3_ENDPOINT="https://hot.ir-central1.arvanstorage.ir"
S3_BUCKET="your-bucket-name"
S3_ACCESS_KEY_ID="your_access_key"
S3_SECRET_ACCESS_KEY="your_secret_key"
S3_REGION="us-east-1"
S3_FORCE_PATH_STYLE="true"

# ==========================================
# Background Maintenance Cron Secret
# ==========================================
# Secret key to authorize hourly recording retention prunes. Generate with: openssl rand -base64 32
CRON_SECRET="generate-a-secure-random-string-here"

